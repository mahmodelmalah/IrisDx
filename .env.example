# =============================================================================
#  IrisDx — Environment Variables Template
#  Copy this file to .env and fill in your values. Never commit .env to Git.
# =============================================================================

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex())")
SECRET_KEY=your-secret-key-here

# Set to "production" when deploying
FLASK_ENV=development

# Absolute path to the trained Keras model (.h5)
# Leave blank to run in MOCK MODE
MODEL_PATH=../IRISRecognizer1.h5

# Maximum upload size in MB
MAX_UPLOAD_MB=16
