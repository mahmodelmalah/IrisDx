# =============================================================================
#  IrisDx — .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.pyo
*.pyd
.Python
pip-log.txt

# --- Virtual Environments ---
venv/
.venv/
env/
ENV/
.env

# --- Flask / App Specific ---
instance/
uploads/          # uploaded iris images (user data — never commit)
*.h5              # trained model weights (too large for Git — use Git LFS or share separately)
*.pkl             # pickled encoders / scalers

# --- IDE & OS ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Logs ---
*.log
logs/

# --- Testing ---
.pytest_cache/
htmlcov/
.coverage
coverage.xml
